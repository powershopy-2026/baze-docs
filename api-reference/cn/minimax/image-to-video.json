{
  "openapi": "3.0.1",
  "info": {
    "title": "MiniMax Overseas - Image to Video",
    "version": "1.0.0",
    "description": "MiniMax Overseas 首帧图生视频渠道子文档。该文档描述当前项目已经实现、且与 MiniMax 官方 image-to-video 能力对应的字段子集。\n\n项目入口为 `/v1/videos`，网关最终会调用上游 `POST https://api.minimax.io/v1/video_generation`。公开 `image` / `input_reference` 会映射为上游 `first_frame_image`。"
  },
  "servers": [
    {
      "url": "baze-api.powerbuyin.top",
      "description": "当前 new-api 网关实例"
    }
  ],
  "tags": [
    {
      "name": "MiniMax Overseas Video",
      "description": "MiniMax Overseas 首帧图生视频能力"
    }
  ],
  "paths": {
    "/v1/videos": {
      "post": {
        "summary": "MiniMax Overseas 首帧图生视频",
        "description": "该接口仅适用于 MiniMax Overseas 首帧图生视频能力。\n\n当前能力边界：\n- 支持模型 `MiniMax-Hailuo-2.3`、`MiniMax-Hailuo-2.3-Fast`、`MiniMax-Hailuo-02`、`I2V-01-Director`、`I2V-01-live`、`I2V-01`\n- 已实现字段：`model`、`image`、`prompt`、`seconds`、`size`\n- `prompt` 在该能力下可省略；是否需要由具体模型能力决定\n- 官方扩展字段通过 `metadata.*` 透传",
        "operationId": "minimaxOverseasImageToVideo",
        "tags": [
          "MiniMax Overseas Video"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageToVideoRequest"
              },
              "examples": {
                "basic_request": {
                  "summary": "基础首帧图生视频请求",
                  "value": {
                    "model": "I2V-01",
                    "image": "https://example.com/assets/first-frame.png",
                    "prompt": "The girl looks at the camera and smiles.",
                    "seconds": "6",
                    "size": "720P"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "提交成功，返回统一 OpenAI 风格视频任务对象。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OpenAIVideo"
                }
              }
            }
          },
          "400": {
            "description": "请求参数不合法，例如缺少 `image`，或传入不支持首帧图生视频的模型。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ImageToVideoRequest": {
        "type": "object",
        "required": [
          "model",
          "image"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "MiniMax-Hailuo-2.3",
              "MiniMax-Hailuo-2.3-Fast",
              "MiniMax-Hailuo-02",
              "I2V-01-Director",
              "I2V-01-live",
              "I2V-01"
            ],
            "description": "MiniMax Overseas 首帧图生视频模型。"
          },
          "image": {
            "type": "string",
            "description": "首帧图片 URL 或 Data URL。网关会映射到上游 `first_frame_image`。"
          },
          "prompt": {
            "type": "string",
            "description": "可选的视频提示词。"
          },
          "seconds": {
            "type": "string",
            "description": "期望时长（秒）。网关会映射到上游 `duration`。"
          },
          "size": {
            "type": "string",
            "description": "期望分辨率。网关会映射到上游 `resolution`。"
          },
          "metadata": {
            "type": "object",
            "description": "MiniMax 官方扩展字段透传区。当前项目支持 `prompt_optimizer`、`fast_pretreatment`、`callback_url`、`aigc_watermark`。",
            "additionalProperties": true
          }
        }
      },
      "OpenAIVideo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "task_id": {
            "type": "string"
          },
          "object": {
            "type": "string",
            "example": "video"
          },
          "model": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "example": "queued"
          },
          "progress": {
            "type": "integer",
            "example": 0
          },
          "created_at": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "data": {}
        }
      }
    }
  }
}
