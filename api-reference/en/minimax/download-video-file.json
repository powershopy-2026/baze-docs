{
  "openapi": "3.0.1",
  "info": {
    "title": "MiniMax Overseas - Download Video File",
    "version": "1.0.0",
    "description": "MiniMax Overseas video file download subdocument. The baze platform entry path is `/v1/videos/{task_id}/content`, which returns the downloadable video content for a completed task."
  },
  "servers": [
    {
      "url": "baze-api.powerbuyin.top",
      "description": "Public baze platform API endpoint"
    }
  ],
  "tags": [
    {
      "name": "MiniMax Overseas Video",
      "description": "MiniMax Overseas video content download"
    }
  ],
  "paths": {
    "/v1/videos/{task_id}/content": {
      "get": {
        "summary": "Download MiniMax Overseas video content",
        "description": "Download the completed video content.\n\nCall this endpoint after the task has completed to retrieve the generated video file through the baze platform.",
        "operationId": "minimaxOverseasDownloadVideoFile",
        "tags": [
          "MiniMax Overseas Video"
        ],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Public video task ID."
          }
        ],
        "responses": {
          "200": {
            "description": "Download succeeded. Returns the video binary stream directly.",
            "content": {
              "video/mp4": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "The task does not exist, or it has not produced downloadable content yet."
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
