{
  "openapi": "3.0.1",
  "info": {
    "title": "MiniMax Overseas - Start End to Video",
    "version": "1.0.0",
    "description": "MiniMax Overseas start-end-to-video subdocument. This subdocument describes the subset of fields currently implemented in the project and mapped to the official MiniMax start-end-to-video capability.\n\nThe platform entry path is `/v1/videos`, and the gateway ultimately calls upstream `POST https://api.minimax.io/v1/video_generation`. Public `images[0]` / `images[1]` map to upstream `first_frame_image` / `last_frame_image`."
  },
  "servers": [
    {
      "url": "baze-api.powerbuyin.top",
      "description": "Current new-api gateway instance"
    }
  ],
  "tags": [
    {
      "name": "MiniMax Overseas Video",
      "description": "MiniMax Overseas start-end-to-video capability"
    }
  ],
  "paths": {
    "/v1/videos": {
      "post": {
        "summary": "MiniMax Overseas start-end to video",
        "description": "This endpoint only applies to the MiniMax Overseas start-end-to-video capability.\n\nCurrent support boundary:\n- Only `MiniMax-Hailuo-02` is supported\n- Implemented fields: `model`, `images`, `prompt`, `seconds`, `size`\n- `images` must contain exactly 2 items in `[first frame, last frame]` order\n- Official extension fields are passed through under `metadata.*`",
        "operationId": "minimaxOverseasStartEndToVideo",
        "tags": [
          "MiniMax Overseas Video"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartEndToVideoRequest"
              },
              "examples": {
                "basic_request": {
                  "summary": "Basic start-end-to-video request",
                  "value": {
                    "model": "MiniMax-Hailuo-02",
                    "images": [
                      "https://example.com/assets/frame-start.png",
                      "https://example.com/assets/frame-end.png"
                    ],
                    "prompt": "The child grows up naturally.",
                    "seconds": "6",
                    "size": "1080P"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submission succeeded. Returns the unified OpenAI-style video task object.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OpenAIVideo"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters, for example when `images` does not contain exactly 2 items.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "StartEndToVideoRequest": {
        "type": "object",
        "required": [
          "model",
          "images"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "MiniMax-Hailuo-02"
            ],
            "description": "MiniMax Overseas start-end-to-video model."
          },
          "images": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "string"
            },
            "description": "Array of start and end frame images. The fixed order is `[first frame, last frame]`."
          },
          "prompt": {
            "type": "string",
            "description": "Optional video prompt."
          },
          "seconds": {
            "type": "string",
            "description": "Requested duration in seconds. The gateway maps it to upstream `duration`."
          },
          "size": {
            "type": "string",
            "description": "Requested resolution. The gateway maps it to upstream `resolution`."
          },
          "metadata": {
            "type": "object",
            "description": "Pass-through area for official MiniMax extension fields. The current project supports `prompt_optimizer`, `callback_url`, and `aigc_watermark`.",
            "additionalProperties": true
          }
        }
      },
      "OpenAIVideo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "task_id": {
            "type": "string"
          },
          "object": {
            "type": "string",
            "example": "video"
          },
          "model": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "example": "queued"
          },
          "progress": {
            "type": "integer",
            "example": 0
          },
          "created_at": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "data": {}
        }
      }
    }
  }
}
