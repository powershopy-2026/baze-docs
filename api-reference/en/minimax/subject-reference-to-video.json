{
  "openapi": "3.0.1",
  "info": {
    "title": "MiniMax Overseas - Subject Reference to Video",
    "version": "1.0.0",
    "description": "MiniMax Overseas subject-reference-to-video subdocument. This subdocument describes the subset of fields currently implemented in the project and mapped to the official MiniMax subject-reference-to-video capability.\n\nThe platform entry path is `/v1/videos`, and the gateway ultimately calls upstream `POST https://api.minimax.io/v1/video_generation`. `subject_reference` is passed through using the official upstream structure."
  },
  "servers": [
    {
      "url": "baze-api.powerbuyin.top",
      "description": "Current new-api gateway instance"
    }
  ],
  "tags": [
    {
      "name": "MiniMax Overseas Video",
      "description": "MiniMax Overseas subject-reference-to-video capability"
    }
  ],
  "paths": {
    "/v1/videos": {
      "post": {
        "summary": "MiniMax Overseas subject-reference to video",
        "description": "This endpoint only applies to the MiniMax Overseas subject-reference-to-video capability.\n\nCurrent support boundary:\n- Only `S2V-01` is supported\n- Implemented fields: `model`, `subject_reference`, `prompt`\n- `prompt` is optional for this capability\n- Official extension fields `prompt_optimizer` and `callback_url` are passed through under `metadata.*`",
        "operationId": "minimaxOverseasSubjectReferenceToVideo",
        "tags": [
          "MiniMax Overseas Video"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubjectReferenceToVideoRequest"
              },
              "examples": {
                "basic_request": {
                  "summary": "Basic subject-reference-to-video request",
                  "value": {
                    "model": "S2V-01",
                    "subject_reference": [
                      {
                        "type": "character",
                        "image": [
                          "https://example.com/assets/subject-reference.png"
                        ]
                      }
                    ],
                    "metadata": {
                      "prompt_optimizer": false
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submission succeeded. Returns the unified OpenAI-style video task object.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OpenAIVideo"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters, for example missing `subject_reference` or sending a model that does not support subject-reference to video.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "SubjectReferenceToVideoRequest": {
        "type": "object",
        "required": [
          "model",
          "subject_reference"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "S2V-01"
            ],
            "description": "MiniMax Overseas subject-reference-to-video model."
          },
          "prompt": {
            "type": "string",
            "description": "Optional video prompt."
          },
          "subject_reference": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/VideoSubjectReference"
            },
            "description": "Official MiniMax subject reference field."
          },
          "metadata": {
            "type": "object",
            "description": "Pass-through area for official MiniMax extension fields. The current project supports `prompt_optimizer` and `callback_url`.",
            "additionalProperties": true
          }
        }
      },
      "VideoSubjectReference": {
        "type": "object",
        "required": [
          "type",
          "image"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Subject type. The current project matches the official docs and supports only `character`."
          },
          "image": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "description": "Array of subject reference images."
          }
        }
      },
      "OpenAIVideo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "task_id": {
            "type": "string"
          },
          "object": {
            "type": "string",
            "example": "video"
          },
          "model": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "example": "queued"
          },
          "progress": {
            "type": "integer",
            "example": 0
          },
          "created_at": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "data": {}
        }
      }
    }
  }
}
