{
  "openapi": "3.0.1",
  "info": {
    "title": "Video Task Status",
    "version": "1.0.0",
    "description": "Documentation for querying asynchronous video tasks. The public endpoint is `/v1/videos/{task_id}` and returns task status, progress, and result data.",
    "license": {
      "name": "Project License",
      "url": "https://github.com/QuantumNous/new-api/blob/main/LICENSE"
    }
  },
  "servers": [
    {
      "url": "https://baze-api.powerbuyin.top",
      "description": "Baze API service endpoint"
    }
  ],
  "tags": [
    {
      "name": "Hailuo Video",
      "description": "Video task status for Hailuo workflows"
    }
  ],
  "paths": {
    "/v1/videos/{task_id}": {
      "get": {
        "summary": "Video Task Status",
        "description": "Query the latest state of an asynchronous video task by task ID.\n\nWhen generation finishes, `metadata.url` can be used to continue accessing the result. If you need the final media content directly, call `/v1/videos/{task_id}/content`.",
        "operationId": "minimaxQueryVideoStatus",
        "tags": [
          "Hailuo Video"
        ],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Public video task ID."
          }
        ],
        "responses": {
          "200": {
            "description": "Query successful.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OpenAIVideo"
                },
                "examples": {
                  "completed": {
                    "summary": "Task completed",
                    "value": {
                      "id": "task_abc123",
                      "object": "video",
                      "model": "MiniMax-Hailuo-2.3",
                      "status": "completed",
                      "progress": 100,
                      "created_at": 1742515200,
                      "completed_at": 1742515235,
                      "metadata": {
                        "url": "https://api.example.com/v1/videos/task_abc123/content"
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Task not found or unavailable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "not_found": {
                    "summary": "Task not found",
                    "value": {
                      "code": "task_not_found",
                      "message": "Task not found or expired",
                      "data": null
                    }
                  }
                }
              }
            }
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "unauthorized": {
                    "summary": "Unauthorized",
                    "value": {
                      "code": "access_denied",
                      "message": "Invalid token",
                      "data": null
                    }
                  }
                }
              }
            },
            "description": "Authentication failed, for example because the token is missing or invalid."
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "quota_exceeded": {
                    "summary": "Quota exceeded or rate limited",
                    "value": {
                      "code": "insufficient_user_quota",
                      "message": "Insufficient quota for this request",
                      "data": null
                    }
                  }
                }
              }
            },
            "description": "Rate limits were hit or the account ran out of quota."
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "internal_error": {
                    "summary": "Internal processing error",
                    "value": {
                      "code": "gen_relay_info_failed",
                      "message": "Internal request processing failed",
                      "data": null
                    }
                  }
                }
              }
            },
            "description": "The server failed while processing the request."
          },
          "502": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "bad_gateway": {
                    "summary": "Bad upstream response",
                    "value": {
                      "code": "bad_response_status_code",
                      "message": "Upstream service returned an invalid response",
                      "data": null
                    }
                  }
                }
              }
            },
            "description": "The upstream service returned an invalid response."
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "service_unavailable": {
                    "summary": "Service unavailable",
                    "value": {
                      "code": "get_channel_failed",
                      "message": "No available channel for the requested model",
                      "data": null
                    }
                  }
                }
              }
            },
            "description": "The upstream service is temporarily unavailable, or no channel is currently available for this model."
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "OpenAIVideo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "object": {
            "type": "string",
            "example": "video"
          },
          "model": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "example": "completed"
          },
          "progress": {
            "type": "integer",
            "example": 100
          },
          "created_at": {
            "type": "integer",
            "format": "int64"
          },
          "completed_at": {
            "type": "integer",
            "format": "int64"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "data": {}
        }
      }
    }
  }
}
