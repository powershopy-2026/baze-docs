{
  "openapi": "3.0.1",
  "info": {
    "title": "Kling Text-to-Video Task - Query Task Status",
    "version": "1.0.0",
    "description": "Query Kling text-to-video task status via `/kling/v1/videos/text2video/{task_id}`."
  },
  "servers": [
    {
      "url": "https://baze-api.powerbuyin.top",
      "description": ""
    }
  ],
  "tags": [
    {
      "name": "Kling",
      "description": "Kling native async task endpoints"
    }
  ],
  "paths": {
    "/kling/v1/videos/text2video/{task_id}": {
      "get": {
        "summary": "Query Kling text-to-video task status",
        "description": "Returns the persisted Kling text-to-video task response. The task_id path parameter is the public task ID returned by the submit endpoint.",
        "operationId": "getKlingText2VideoStatus",
        "tags": [
          "Kling"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "Content-Type",
            "in": "header",
            "required": true,
            "description": "Data exchange format",
            "schema": {
              "type": "string",
              "default": "application/json"
            }
          },
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "description": "Text-to-video task ID. Provide the value directly in the request path. Choose either task_id or external_task_id for querying.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Task status response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FetchResponse"
                },
                "example": {
                  "code": 0,
                  "message": "string",
                  "request_id": "string",
                  "data": {
                    "task_id": "string",
                    "task_status": "string",
                    "task_status_msg": "string",
                    "task_info": {
                      "external_task_id": "string"
                    },
                    "task_result": {
                      "videos": [
                        {
                          "id": "string",
                          "url": "string",
                          "watermark_url": "string",
                          "duration": "string"
                        }
                      ]
                    },
                    "watermark_info": {
                      "enabled": true
                    },
                    "final_unit_deduction": "string",
                    "created_at": 1722769557708,
                    "updated_at": 1722769557708
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Pass `Authorization: Bearer <token>` in the request header."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "description": "Error details returned by the gateway or upstream provider."
          }
        }
      },
      "FetchResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "Error code; see error codes for details."
          },
          "message": {
            "type": "string",
            "description": "Error message."
          },
          "request_id": {
            "type": "string",
            "description": "Request ID, system-generated, used for request tracking and troubleshooting."
          },
          "data": {
            "type": "object",
            "properties": {
              "task_id": {
                "type": "string",
                "description": "Task ID, system-generated."
              },
              "task_status": {
                "type": "string",
                "enum": [
                  "submitted",
                  "processing",
                  "succeed",
                  "failed"
                ],
                "description": "Task status. Enum values: submitted, processing, succeed, failed."
              },
              "task_status_msg": {
                "type": "string",
                "description": "Task status message. When the task fails, shows the failure reason (e.g., triggered platform content moderation)."
              },
              "task_info": {
                "type": "object",
                "description": "Task creation parameter information.",
                "properties": {
                  "external_task_id": {
                    "type": "string",
                    "description": "Client-provided custom task ID."
                  }
                }
              },
              "task_result": {
                "type": "object",
                "description": "Task result.",
                "properties": {
                  "videos": {
                    "type": "array",
                    "description": "List of generated videos.",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "description": "Generated video ID; globally unique."
                        },
                        "url": {
                          "type": "string",
                          "description": "Generated video URL (Note: for information security, generated images/videos will be cleaned up after 30 days; please save them promptly)."
                        },
                        "watermark_url": {
                          "type": "string",
                          "description": "Watermarked video download URL, anti-leech format."
                        },
                        "duration": {
                          "type": "string",
                          "description": "Total video duration in seconds."
                        }
                      }
                    }
                  }
                }
              },
              "watermark_info": {
                "type": "object",
                "description": "Watermark information.",
                "properties": {
                  "enabled": {
                    "type": "boolean",
                    "description": "Whether watermark is enabled."
                  }
                }
              },
              "final_unit_deduction": {
                "type": "string",
                "description": "Final unit deduction value for the task."
              },
              "created_at": {
                "type": "integer",
                "format": "int64",
                "description": "Task creation time, Unix timestamp in milliseconds."
              },
              "updated_at": {
                "type": "integer",
                "format": "int64",
                "description": "Task update time, Unix timestamp in milliseconds."
              }
            }
          }
        }
      }
    }
  }
}
