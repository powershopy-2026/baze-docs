{
  "openapi": "3.0.1",
  "info": {
    "title": "Wan Image to Video (First Frame)",
    "version": "1.0.0",
    "description": "Aliyun Wan 2.1-2.6 series first-frame image-to-video capability documentation. The unified API endpoint is `/ali/api/v1/services/aigc/video-generation/video-synthesis`, used to create asynchronous video generation tasks.\n\nSupported models: `wan2.6-i2v-flash`, `wan2.6-i2v`, `wan2.5-i2v-preview`, `wan2.2-i2v-plus`, `wan2.2-i2v-flash`, `wanx2.1-i2v-turbo`, `wanx2.1-i2v-plus`.",
    "license": {
      "name": "Project License",
      "url": "https://github.com/QuantumNous/new-api/blob/main/LICENSE"
    }
  },
  "servers": [
    {
      "url": "https://baze-api.powerbuyin.top",
      "description": "Baze API server endpoint"
    }
  ],
  "tags": [
    {
      "name": "Wan Legacy Video",
      "description": "Ali wan 2.1-2.6 image-to-video capability"
    }
  ],
  "paths": {
    "/ali/api/v1/services/aigc/video-generation/video-synthesis": {
      "post": {
        "summary": "Create Wan image-to-video task (first frame)",
        "description": "Submit an asynchronous Wan 2.1-2.6 image-to-video task, generating a video based on a first frame image.\n\nAfter submitting a task, query its status via `GET /ali/api/v1/tasks/{task_id}`.",
        "operationId": "aliLegacyI2VFirstFrameCreate",
        "tags": [
          "Wan Legacy Video"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LegacyI2VRequest"
              },
              "examples": {
                "basic_request": {
                  "summary": "Basic first frame image-to-video request",
                  "value": {
                    "model": "wan2.6-i2v",
                    "input": {
                      "prompt": "A cat starts walking from rest, the scene is full of energy.",
                      "img_url": "https://example.com/assets/cat.png"
                    },
                    "parameters": {
                      "resolution": "1080P",
                      "duration": 5,
                      "prompt_extend": true,
                      "watermark": false
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submitted successfully. Returns a video task object.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoTaskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed, e.g. missing or invalid token.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit triggered or insufficient account quota.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "An internal error occurred while processing the request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/ali/api/v1/tasks/{task_id}": {
      "get": {
        "summary": "Query Wan image-to-video task status (first frame)",
        "description": "Query the status and result of a video generation task by task ID.\n\nTask status flow: PENDING (queued) -> RUNNING (processing) -> SUCCEEDED (success) / FAILED (failure).",
        "operationId": "aliLegacyI2VFirstFrameQuery",
        "tags": [
          "Wan Legacy Video"
        ],
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Video generation task ID."
          }
        ],
        "responses": {
          "200": {
            "description": "Query successful. Returns the task status.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VideoTaskQueryResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Task does not exist or has expired.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Pass `Authorization: Bearer <token>` in the request header."
      }
    },
    "schemas": {
      "LegacyI2VRequest": {
        "type": "object",
        "required": [
          "model",
          "input"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "wan2.6-i2v-flash",
              "wan2.6-i2v",
              "wan2.5-i2v-preview",
              "wan2.2-i2v-plus",
              "wan2.2-i2v-flash",
              "wanx2.1-i2v-turbo",
              "wanx2.1-i2v-plus"
            ],
            "description": "Model name."
          },
          "input": {
            "$ref": "#/components/schemas/LegacyI2VInput"
          },
          "parameters": {
            "$ref": "#/components/schemas/LegacyI2VParameters"
          }
        }
      },
      "LegacyI2VInput": {
        "type": "object",
        "required": [
          "img_url"
        ],
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Optional prompt."
          },
          "negative_prompt": {
            "type": "string",
            "description": "Negative prompt describing content you do not want in the video. Up to 500 characters.",
            "maxLength": 500
          },
          "img_url": {
            "type": "string",
            "description": "First frame image URL or Base64 encoded string."
          },
          "audio_url": {
            "type": "string",
            "description": "Optional audio URL. Only supported by wan2.6 and wan2.5 models."
          },
          "template": {
            "type": "string",
            "description": "Optional video effect template."
          }
        }
      },
      "LegacyI2VParameters": {
        "type": "object",
        "properties": {
          "resolution": {
            "type": "string",
            "enum": [
              "480P",
              "720P",
              "1080P"
            ],
            "description": "Output video resolution."
          },
          "duration": {
            "type": "integer",
            "description": "Video duration in seconds."
          },
          "prompt_extend": {
            "type": "boolean",
            "description": "Whether to enable intelligent prompt rewriting. Default true.",
            "default": true
          },
          "shot_type": {
            "type": "string",
            "enum": [
              "single",
              "multi"
            ],
            "description": "Shot type. Only supported by wan2.6 models."
          },
          "audio": {
            "type": "boolean",
            "description": "Whether to generate a video with audio. Only supported by `wan2.6-i2v-flash`."
          },
          "watermark": {
            "type": "boolean",
            "description": "Whether to add a watermark to the video. Default false.",
            "default": false
          },
          "seed": {
            "type": "integer",
            "description": "Random seed, range [0, 2147483647].",
            "minimum": 0,
            "maximum": 2147483647
          }
        }
      },
      "VideoTaskResponse": {
        "type": "object",
        "properties": {
          "output": {
            "type": "object",
            "properties": {
              "task_id": {
                "type": "string",
                "description": "Video generation task ID."
              },
              "task_status": {
                "type": "string",
                "enum": [
                  "PENDING"
                ],
                "description": "Task status, returns PENDING after submission."
              }
            }
          },
          "request_id": {
            "type": "string",
            "description": "Request ID."
          }
        }
      },
      "VideoTaskQueryResponse": {
        "type": "object",
        "properties": {
          "output": {
            "type": "object",
            "properties": {
              "task_id": {
                "type": "string",
                "description": "Video generation task ID."
              },
              "task_status": {
                "type": "string",
                "enum": [
                  "PENDING",
                  "RUNNING",
                  "SUCCEEDED",
                  "FAILED"
                ],
                "description": "Task status."
              },
              "video_url": {
                "type": "string",
                "description": "Download URL for the generated video. Returned only when the task succeeds."
              },
              "orig_prompt": {
                "type": "string",
                "description": "Original input prompt."
              },
              "actual_prompt": {
                "type": "string",
                "description": "Optimized prompt (when prompt_extend is enabled)."
              }
            }
          },
          "usage": {
            "type": "object",
            "description": "Usage information.",
            "additionalProperties": true
          },
          "request_id": {
            "type": "string",
            "description": "Request ID."
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Error code."
          },
          "message": {
            "type": "string",
            "description": "Error message."
          },
          "request_id": {
            "type": "string",
            "description": "Request ID."
          }
        }
      }
    }
  }
}
