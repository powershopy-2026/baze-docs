{
  "openapi": "3.0.1",
  "info": {
    "title": "Claude 消息接口",
    "version": "1.0.0",
    "description": "完全兼容 Claude Messages API 格式\n支持多轮对话和单次查询\n支持文本、图像等多模态内容"
  },
  "servers": [
    {
      "url": "/",
      "description": "Current gateway instance"
    }
  ],
  "tags": [
    {
      "name": "Zhipu Claude Messages",
      "description": "Zhipu V4 native Claude-compatible messages"
    }
  ],
  "paths": {
    "/v1/messages": {
      "post": {
        "summary": "Create a Zhipu Claude-compatible message",
        "description": "Routes the request to Zhipu V4's native Claude-compatible messages endpoint.",
        "operationId": "createZhipuClaudeMessage",
        "tags": [
          "Zhipu Claude Messages"
        ],
        "parameters": [
          {
            "name": "anthropic-version",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "default": "2023-06-01"
            },
            "description": "Claude API version forwarded to Zhipu. Defaults to `2023-06-01` when omitted."
          },
          {
            "name": "anthropic-beta",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Optional Claude beta feature header forwarded when provided."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ZhipuClaudeMessagesRequest"
              },
              "examples": {
                "glmBasic": {
                  "summary": "GLM Claude request",
                  "value": {
                    "model": "glm-4.7",
                    "messages": [
                      {
                        "role": "user",
                        "content": "Hello"
                      }
                    ],
                    "max_tokens": 100
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Claude-compatible response returned by Zhipu.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClaudeMessagesResponse"
                }
              },
              "text/event-stream": {
                "schema": {
                  "type": "string",
                  "description": "Claude-style SSE stream when `stream` is true."
                }
              }
            }
          },
          "400": {
            "description": "Invalid request body or upstream validation failure.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClaudeErrorResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Gateway API token."
      }
    },
    "schemas": {
      "ZhipuClaudeMessagesRequest": {
        "type": "object",
        "required": [
          "model",
          "messages",
          "max_tokens"
        ],
        "properties": {
          "model": {
            "type": "string",
            "enum": [
              "glm-5-turbo",
              "glm-5",
              "glm-4.7",
              "glm-4.7-flash",
              "glm-4.5-air"
            ],
            "description": "Zhipu V4 model routed through the native Claude-compatible endpoint."
          },
          "messages": {
            "type": "array",
            "description": "Claude-style conversation messages.",
            "items": {
              "$ref": "#/components/schemas/ClaudeMessage"
            }
          },
          "max_tokens": {
            "type": "integer",
            "minimum": 1,
            "description": "Maximum number of output tokens."
          },
          "system": {
            "description": "Optional system prompt as a string or text blocks with optional cache control metadata.",
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/TextBlock"
                }
              }
            ]
          },
          "temperature": {
            "type": "number",
            "description": "Sampling temperature."
          },
          "top_p": {
            "type": "number",
            "description": "Nucleus sampling probability."
          },
          "stop_sequences": {
            "type": "array",
            "description": "Custom stop sequences.",
            "items": {
              "type": "string"
            }
          },
          "stream": {
            "type": "boolean",
            "description": "Whether to request a Claude-style SSE stream."
          }
        },
        "additionalProperties": true
      },
      "ClaudeMessage": {
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant"
            ],
            "description": "Message role."
          },
          "content": {
            "description": "Text content or an array of Claude content blocks accepted by Zhipu upstream.",
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/ContentBlock"
                }
              }
            ]
          }
        }
      },
      "ContentBlock": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "description": "Claude content block type."
          },
          "text": {
            "type": "string",
            "description": "Text for `text` blocks."
          },
          "cache_control": {
            "$ref": "#/components/schemas/CacheControl"
          }
        },
        "additionalProperties": true
      },
      "TextBlock": {
        "type": "object",
        "required": [
          "type",
          "text"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "text"
            ],
            "description": "System text block type."
          },
          "text": {
            "type": "string",
            "description": "System instruction text."
          },
          "cache_control": {
            "$ref": "#/components/schemas/CacheControl"
          }
        }
      },
      "CacheControl": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "description": "Prompt cache control type."
          }
        },
        "description": "Prompt caching metadata forwarded to Zhipu when supplied."
      },
      "ClaudeMessagesResponse": {
        "type": "object",
        "description": "Claude-compatible message response returned by the upstream provider.",
        "additionalProperties": true
      },
      "ClaudeErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "object",
            "required": [
              "type",
              "message"
            ],
            "properties": {
              "type": {
                "type": "string",
                "description": "Claude-style error type."
              },
              "message": {
                "type": "string",
                "description": "Human-readable error message."
              }
            }
          }
        }
      }
    }
  }
}